            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-video-url",
              "leftValue": "={{ $json.video_url }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 0],
      "id": "check-video-node",
      "name": "Has Video?"
    },
    {
      "parameters": {
        "jsCode": "const generateResponse = $('Generate Content').first().json;\nconst videoUrl = $('Pick Source Video').first().json.video_url;\nconst webhookBody = $('Webhook').first().json.body;\n\nconst reels = generateResponse.reels || [];\n\nreturn reels.map(reel => ({\n  json: {\n    record_id: reel.record_id || '',\n    hook_text: reel.hook || '',\n    body_text: reel.text_on_video || '',\n    source_video_url: videoUrl,\n    text_direction: 'rtl',\n    client_id: webhookBody.client_id || ''\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, -80],
      "id": "prepare-reels-node",
      "name": "Prepare Render Jobs"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/render",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ \"record_id\": $json.record_id, \"hook_text\": $json.hook_text, \"body_text\": $json.body_text, \"source_video_url\": $json.source_video_url, \"text_direction\": $json.text_direction, \"client_id\": $json.client_id }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1100, -80],
      "id": "render-request-node",
      "name": "POST Render"
    },
    {
      "parameters": {
        "jsCode": "const generateResponse = $('Generate Content').first().json;\nconst renderResults = $('POST Render').all();\n\nconst renderJobs = renderResults.map(r => ({\n  job_id: r.json.job_id,\n  status: r.json.status\n}));\n\nreturn [{\n  json: {\n    ...generateResponse,\n    render_jobs: renderJobs,\n    render_count: renderJobs.length\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, -80],
      "id": "build-response-node",
      "name": "Build Response"
    },
    {
